generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Enums (Better than strings)
enum Role {
  CITIZEN
  ADMIN
}

enum ReportStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

// 2. User Model
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String   // Made required as requested
  role      Role     @default(CITIZEN)
  createdAt DateTime @default(now())
  
  reports   Report[]
  comments  Comment[]
}

// 3. Report Model
model Report {
  id          Int          @id @default(autoincrement())
  title       String
  description String?      // Shown in the "SPA" detail view
  photoUrl    String       // Made required (Main UI element)
  latitude    Float
  longitude   Float
  status      ReportStatus @default(PENDING)
  
  // Security for "Magic Links"
  // This random string is generated when report is created.
  // The email link will look like: mysite.com/api/resolve?id=1&secret=abc-123-xyz
  accessSecret String      @default(uuid())

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  resolvedAt  DateTime? 

  // RELATIONS
  userId      Int
  user        User         @relation(fields: [userId], references: [id])
  
  categoryId  Int
  category    Category     @relation(fields: [categoryId], references: [id])
  
  comments    Comment[]

  // INDEXES (Optimized for your Search/Filter bars)
  @@index([status])                 // Fast filtering by status
  @@index([userId])                 // Fast "My Reports"
  @@index([categoryId])             // Fast filtering by Category
  @@index([latitude, longitude])    // Fast "Nearby" calculations
  @@index([title])                  // Fast Search Bar lookups
}

// 4. Category Model (The bridge between Report and Department)
model Category {
  id           Int        @id @default(autoincrement())
  name         String     // e.g., "Potholes", "Garbage", "Noise"
  
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  
  reports      Report[]
}

// 5. Department Model
model Department {
  id         Int        @id @default(autoincrement())
  name       String     // e.g., "Road Maintenance", "Sanitation"
  email      String     @unique // Where the Nodemailer emails go
  
  categories Category[] // One dept can handle multiple categories
}

// 6. Comment Model
model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  
  reportId  Int
  report    Report   @relation(fields: [reportId], references: [id])
}