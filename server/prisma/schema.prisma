generator client {
  provider      = "prisma-client-js"
  // Added "linux-musl-openssl-3.0.x" to ensure compatibility with Render
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  CITIZEN
  ADMIN
}

enum IssueStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

enum DepartmentWorkStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// ==========================================
// MODELS
// ==========================================

model User {
  id                   Int       @id @default(autoincrement())
  email                String    @unique
  password             String
  name                 String
  role                 Role      @default(CITIZEN)
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  
  // Relationships
  civicIssues          CivicIssue[]
  comments             Comment[]
}

model Department {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique

  // Relationships
  categories    Category[] 
  interventions Intervention[]
}

model Category {
  id           Int        @id @default(autoincrement())
  name         String
  
  // Strict 1-to-Many
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  
  // Relationships
  civicIssues  CivicIssue[]

  @@index([departmentId])
}

model CivicIssue {
  id           Int         @id @default(autoincrement())
  title        String
  description  String?
  photoUrl     String
  latitude     Float
  longitude    Float    
  status       IssueStatus @default(PENDING)
  
  accessSecret String?     @unique @default(uuid())
  expiresAt    DateTime?

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  resolvedAt   DateTime? 

  // Strict 1-to-Many
  userId       Int
  user         User        @relation(fields: [userId], references: [id])
  
  categoryId   Int
  category     Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Relationships
  interventions Intervention[]
  comments      Comment[]
  
  @@index([status])
  @@index([userId])
  @@index([categoryId])
  @@index([latitude, longitude]) 
  @@index([title])               
}

model Intervention {
  id            Int                   @id @default(autoincrement())
  civicIssueId  Int
  departmentId  Int

  description   String?
  status        DepartmentWorkStatus  @default(PENDING)

  assignedAt    DateTime              @default(now())
  updatedAt     DateTime              @updatedAt 
  completedAt   DateTime?

  // RELATIONS
  civicIssue    CivicIssue            @relation(fields: [civicIssueId], references: [id], onDelete: Cascade)
  department    Department            @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([civicIssueId, departmentId])
}

model Comment {
  id           Int      @id @default(autoincrement())
  text         String
  
  createdAt    DateTime @default(now())

  // Strict 1-to-Many
  userId       Int
  user         User       @relation(fields: [userId], references: [id])
  
  civicIssueId Int
  civicIssue   CivicIssue @relation(fields: [civicIssueId], references: [id], onDelete: Cascade)

  @@index([civicIssueId])
}